  "questions": [
    { "type": "mcq", "prompt": "Which expression is NOT a polynomial?", "choices": ["x³ − 5x + 7", "3x² + 2x − 1", "x + x⁻¹", "4x⁴"], "answer": "C", "explanation": "x⁻¹ = 1/x has a negative exponent, so x + x⁻¹ is not a polynomial." },
    { "type": "mcq", "prompt": "The degree of 5a⁴b + 3a²b⁷ − 9 is:", "choices": ["4", "7", "9", "5"], "answer": "C", "explanation": "The degree is the largest sum of exponents in any term: 2 + 7 = 9." },
    { "type": "mcq", "prompt": "Find (3x² + 2x − 1) + (x² − 5x + 4):", "choices": ["4x² − 3x + 3", "4x² + 7x + 3", "2x² + 3x − 5", "4x² − 3x − 3"], "answer": "A", "explanation": "Combine like terms: (3+1)x² + (2−5)x + (−1+4) = 4x² − 3x + 3." },
    { "type": "mcq", "prompt": "Find (5x³ − 2x + 1) − (2x³ + x² − 3x):", "choices": ["3x³ − x² + x + 1", "3x³ + x² − 5x + 1", "7x³ + x² − 5x", "3x³ − x² − 5x"], "answer": "A", "explanation": "Distribute −1: 5x³ − 2x + 1 − 2x³ − x² + 3x = 3x³ − x² + x + 1." },
    { "type": "mcq", "prompt": "Find (x + 3)(x − 5) using FOIL:", "choices": ["x² − 2x − 15", "x² + 8x − 15", "x² − 2x + 15", "x² + 2x − 15"], "answer": "A", "explanation": "F: x², O: −5x, I: 3x, L: −15. Sum: x² − 2x − 15." },
    { "type": "mcq", "prompt": "Which operation is the FOIL method used for?", "choices": ["Two polynomials of any degree", "Adding two binomials", "Multiplying two binomials", "Subtracting polynomials"], "answer": "C", "explanation": "FOIL specifically applies to multiplying two binomials." },
    { "type": "mcq", "prompt": "Find 3x(2x² − x + 4):", "choices": ["6x³ − 3x² + 12x", "6x² − 3x + 12", "5x³ − 4x² + 7x", "6x³ + 12x"], "answer": "A", "explanation": "Distribute: 3x(2x²) + 3x(−x) + 3x(4) = 6x³ − 3x² + 12x." },
    { "type": "mcq", "prompt": "The sum of two polynomials is always:", "choices": ["A polynomial", "A monomial", "A trinomial", "Always degree 3"], "answer": "A", "explanation": "Polynomials are closed under addition — the sum is always a polynomial." },
    { "type": "mcq", "prompt": "Find (2x − 3)²:", "choices": ["4x² − 9", "4x² + 9", "4x² − 12x + 9", "4x² − 6x + 9"], "answer": "C", "explanation": "(2x−3)² = (2x)² + 2(2x)(−3) + (−3)² = 4x² − 12x + 9." },
    { "type": "mcq", "prompt": "Find (x + 2)(x² − 3x + 1):", "choices": ["x³ − x² − 5x + 2", "x³ + x² + 7x − 2", "x³ − x² + 5x + 2", "x³ + x² − 5x + 2"], "answer": "A", "explanation": "Distribute: x(x²−3x+1) + 2(x²−3x+1) = x³−3x²+x+2x²−6x+2 = x³−x²−5x+2." },
    { "type": "mcq", "prompt": "Find (a + b)(a − b):", "choices": ["a² − b²", "a² + 2ab − b²", "a² − 2ab − b²", "a² + b²"], "answer": "A", "explanation": "Difference of squares pattern: (a+b)(a−b) = a² − b²." },
    { "type": "mcq", "prompt": "Which polynomial is a binomial?", "choices": ["x³ + 2x² − x", "x + 1", "x² + 3x − 7", "5"], "answer": "B", "explanation": "A binomial has exactly 2 terms. x + 1 has 2 terms." },
    { "type": "mcq", "prompt": "Find (3x − 1)(x + 2)(x − 1). First, (3x−1)(x+2) =", "choices": ["3x² + 5x − 2", "3x² + x − 2", "3x² − 5x + 2", "3x² + 7x − 2"], "answer": "A", "explanation": "FOIL: 3x² + 6x − x − 2 = 3x² + 5x − 2." },
    { "type": "mcq", "prompt": "Find (x² + 3)(x² − 3):", "choices": ["x⁴ − 9", "x⁴ + 9", "x⁴ − 6x² + 9", "x⁴ − 3x² − 9"], "answer": "A", "explanation": "Difference of squares: (x²)² − 3² = x⁴ − 9." },
    { "type": "mcq", "prompt": "Simplify (5x² − 2x + 3) − (x² + 4x − 1):", "choices": ["4x² − 6x + 4", "6x² + 2x + 2", "4x² + 2x + 4", "4x² − 6x + 2"], "answer": "A", "explanation": "Distribute −1 and combine: (5−1)x² + (−2−4)x + (3+1) = 4x² − 6x + 4." }
  ]
}
