  "questions": [
    {
      "type": "mcq",
      "prompt": "What is the axis of symmetry of $f(x) = x^2 + 6x + 8$?",
      "choices": ["$x = -3$", "$x = 3$", "$x = -6$", "$x = 6$"],
      "answer": "A",
      "explanation": "$x = -b/(2a) = -6/(2 \\cdot 1) = -3$."
    },
    {
      "type": "mcq",
      "prompt": "What is the vertex of $f(x) = x^2 - 4x + 3$?",
      "choices": ["$(2, -1)$", "$(-2, 15)$", "$(2, 3)$", "$(4, 3)$"],
      "answer": "A",
      "explanation": "$x = -(-4)/2 = 2$ and $f(2) = 4 - 8 + 3 = -1$."
    },
    {
      "type": "mcq",
      "prompt": "Which statement is true for $f(x) = -2x^2 + 8x - 1$?",
      "choices": [
        "Opens down; has a maximum",
        "Opens up; has a minimum",
        "Opens down; has a minimum",
        "Opens up; has a maximum"
      ],
      "answer": "A",
      "explanation": "$a = -2 < 0$, so the parabola opens down and its vertex is a maximum."
    },
    {
      "type": "mcq",
      "prompt": "What is the $y$-intercept of $f(x) = 3x^2 - 5x + 7$?",
      "choices": ["$(0, 7)$", "$(0, 3)$", "$(0, -5)$", "$(7, 0)$"],
      "answer": "A",
      "explanation": "The $y$-intercept of $ax^2 + bx + c$ is always $(0, c) = (0, 7)$."
    },
    {
      "type": "mcq",
      "prompt": "What is the range of $f(x) = x^2 + 2$?",
      "choices": ["$y \\geq 2$", "$y \\leq 2$", "all real numbers", "$y \\geq 0$"],
      "answer": "A",
      "explanation": "Vertex $(0, 2)$ with $a > 0$ (opens up), so $y \\geq 2$."
    },
    {
      "type": "mcq",
      "prompt": "What is the range of $f(x) = -x^2 + 4x$?",
      "choices": ["$y \\leq 4$", "$y \\geq 4$", "$y \\leq 2$", "all real numbers"],
      "answer": "A",
      "explanation": "Vertex at $x = 2$, $f(2) = 4$; opens down, so $y \\leq 4$."
    },
    {
      "type": "mcq",
      "prompt": "What is the domain of $f(x) = -7x^2 + 21x - 8$?",
      "choices": ["all real numbers", "$x \\geq 1.5$", "$x \\leq 1.5$", "$x \\geq 0$"],
      "answer": "A",
      "explanation": "The domain of every quadratic function is all real numbers."
    },
    {
      "type": "mcq",
      "prompt": "What is the minimum value of $f(x) = 2x^2 - 8x + 3$?",
      "choices": ["$-5$", "$3$", "$2$", "$-8$"],
      "answer": "A",
      "explanation": "$x = 8/4 = 2$ and $f(2) = 8 - 16 + 3 = -5$."
    },
    {
      "type": "mcq",
      "prompt": "What is the average rate of change of $f(x) = x^2$ over $[1, 3]$?",
      "choices": ["$4$", "$8$", "$2$", "$9$"],
      "answer": "A",
      "explanation": "$(f(3) - f(1))/(3 - 1) = (9 - 1)/2 = 4$."
    },
    {
      "type": "mcq",
      "prompt": "What is the average rate of change of $f(x) = -x^2 + 2x - 1$ over $[-4, 4]$?",
      "choices": ["$2$", "$-2$", "$16$", "$-17/4$"],
      "answer": "A",
      "explanation": "$(f(4) - f(-4))/8 = (-9 - (-25))/8 = 16/8 = 2$."
    },
    {
      "type": "mcq",
      "prompt": "A table gives $f(-3) = 48$ and $f(3) = -24$. What is the average rate of change over $[-3, 3]$?",
      "choices": ["$-12$", "$12$", "$-72$", "$-4$"],
      "answer": "A",
      "explanation": "$(-24 - 48)/(3 - (-3)) = -72/6 = -12$."
    },
    {
      "type": "mcq",
      "prompt": "Which function has the greater maximum: $f(x) = -(x-1)^2 + 3$ or $g(x) = -(x+2)^2 + 5$?",
      "choices": [
        "$g(x)$; $5 > 3$",
        "$f(x)$; $1 > -2$",
        "$f(x)$; $3 > -5$",
        "They are equal"
      ],
      "answer": "A",
      "explanation": "Maximum of $f$ is $3$ (vertex $y$-value); maximum of $g$ is $5$; $5 > 3$."
    },
    {
      "type": "mcq",
      "prompt": "What is the axis of symmetry of $f(x) = -3x^2 - 9x + 2$?",
      "choices": ["$x = -1.5$", "$x = 1.5$", "$x = -3$", "$x = 3$"],
      "answer": "A",
      "explanation": "$x = -(-9)/(2 \\cdot (-3)) = 9/(-6) = -1.5$."
    },
    {
      "type": "mcq",
      "prompt": "What is the vertex of $f(x) = x^2 - 10x + 5$?",
      "choices": ["$(5, -20)$", "$(-5, 80)$", "$(5, 5)$", "$(10, 5)$"],
      "answer": "A",
      "explanation": "$x = 10/2 = 5$ and $f(5) = 25 - 50 + 5 = -20$."
    },
    {
      "type": "mcq",
      "prompt": "Does $f(x) = 9x - 1 - 18x^2$ have a maximum or a minimum value?",
      "choices": [
        "Maximum, because $a = -18$",
        "Minimum, because $a = 9$",
        "Minimum, because $c = -1$",
        "Neither"
      ],
      "answer": "A",
      "explanation": "Rewrite as $-18x^2 + 9x - 1$: $a = -18 < 0$, so it opens down and has a maximum."
    }
  ]
}
