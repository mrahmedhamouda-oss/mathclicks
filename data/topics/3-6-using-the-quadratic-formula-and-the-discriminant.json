  "questions": [
    { "type": "mcq", "prompt": "Solve x² + 5x + 6 = 0 using the Quadratic Formula.", "choices": ["x = −2, −3", "x = 2, 3", "x = −1, −6", "x = 1, 6"], "answer": "A", "explanation": "Discriminant = 1. x = (−5 ± 1)/2, so x = −2 or −3." },
    { "type": "mcq", "prompt": "In the Quadratic Formula, the discriminant is:", "choices": ["b² + 4ac", "b² − 4ac", "−b/2a", "√(b² − 4ac)"], "answer": "B", "explanation": "The discriminant is b² − 4ac, the expression under the radical." },
    { "type": "mcq", "prompt": "If b² − 4ac = 0, the equation has:", "choices": ["2 real irrational roots", "2 complex roots", "1 real rational root", "No solution"], "answer": "C", "explanation": "A discriminant of 0 means exactly one real rational root (a double root)." },
    { "type": "mcq", "prompt": "For x² − 6x + 9 = 0, the discriminant is:", "choices": ["0", "−36", "72", "36"], "answer": "A", "explanation": "b² − 4ac = 36 − 4(1)(9) = 36 − 36 = 0." },
    { "type": "mcq", "prompt": "Which equation has 2 complex roots?", "choices": ["x² − x − 6 = 0", "x² + 4x + 8 = 0", "x² − 4 = 0", "2x² − 3x − 2 = 0"], "answer": "B", "explanation": "Discriminant = 16 − 32 = −16 < 0, so there are 2 complex roots." },
    { "type": "mcq", "prompt": "Solve 2x² − 3x − 2 = 0 using the Quadratic Formula:", "choices": ["x = 2, −0.5", "x = −2, 0.5", "x = 1, −2", "x = ±√2"], "answer": "A", "explanation": "Disc = 9 + 16 = 25. x = (3 ± 5)/4 → x = 2 or x = −0.5." },
    { "type": "mcq", "prompt": "The equation x² + 2x + 5 = 0 has:", "choices": ["2 real rational roots", "2 real irrational roots", "2 complex roots", "1 real root"], "answer": "C", "explanation": "Discriminant = 4 − 20 = −16 < 0 → 2 complex roots." },
    { "type": "mcq", "prompt": "For 3x² + 5x − 2 = 0, what is a in the Quadratic Formula?", "choices": ["5", "−2", "3", "1"], "answer": "C", "explanation": "a is the coefficient of x², so a = 3." },
    { "type": "mcq", "prompt": "Solve x² − 7x + 12 = 0 using the Quadratic Formula:", "choices": ["x = 3, 4", "x = −3, −4", "x = 6, 2", "x = 7, 0"], "answer": "A", "explanation": "Disc = 49 − 48 = 1. x = (7 ± 1)/2 = 4 or 3." },
    { "type": "mcq", "prompt": "If b² − 4ac = 16 and 16 is a perfect square, the roots are:", "choices": ["2 real irrational", "2 complex", "2 real rational", "1 real root"], "answer": "C", "explanation": "A positive perfect-square discriminant → 2 real, rational roots." },
    { "type": "mcq", "prompt": "For x² + x + 1 = 0, the discriminant is:", "choices": ["3", "−3", "5", "0"], "answer": "B", "explanation": "b² − 4ac = 1 − 4 = −3." },
    { "type": "mcq", "prompt": "Solve 4x² − 4x + 1 = 0:", "choices": ["x = 1/2", "x = ±1/2", "x = 1", "x = 1/4"], "answer": "A", "explanation": "Disc = 16 − 16 = 0, so x = 4/8 = 1/2 (one repeated root)." },
    { "type": "mcq", "prompt": "Which gives 2 real irrational roots?", "choices": ["x² + 4 = 0", "x² − 4x + 4 = 0", "x² − 3 = 0", "x² + x + 1 = 0"], "answer": "C", "explanation": "x² − 3 = 0 → disc = 12, not a perfect square → 2 real irrational roots." },
    { "type": "mcq", "prompt": "In x = (−b ± √(b²−4ac)) / 2a, when the ± gives two different values, the equation has:", "choices": ["1 solution", "2 solutions", "no solution", "infinite solutions"], "answer": "B", "explanation": "The ± produces two separate values, giving 2 solutions." },
    { "type": "mcq", "prompt": "Solve x² − 4x − 1 = 0 (exact):", "choices": ["x = 2 ± √5", "x = −2 ± √5", "x = 4 ± √5", "x = ±√5"], "answer": "A", "explanation": "Disc = 16 + 4 = 20. x = (4 ± √20)/2 = (4 ± 2√5)/2 = 2 ± √5." }
  ]
}
